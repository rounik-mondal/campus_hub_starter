generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_k75rKOwAIGyH@ep-rough-resonance-aksafavu-pooler.c-3.us-west-2.aws.neon.tech/campusevent?sslmode=require&channel_binding=require"
}

enum Role {
  student
  college_admin
  super_admin
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

enum EventScope {
  GLOBAL
  COLLEGE
}

model College {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users  User[]
  events Event[]
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(student)

  // college mapping
  collegeId   String?
  collegeName String? // for "Other" option

  createdAt DateTime @default(now())

  // relations
  college       College?       @relation(fields: [collegeId], references: [id])
  registrations Registration[]
  feedbacks     Feedback[]
  adminLogs     AdminLog[]
  Event         Event[]

  @@index([email])
  @@index([collegeId])
}

model Event {
  id          String     @id @default(uuid())
  collegeId   String
  title       String
  description String
  category    String
  location    String
  scope       EventScope @default(COLLEGE)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime   @default(now())

  createdBy String

  college       College        @relation(fields: [collegeId], references: [id])
  registrations Registration[]
  feedbacks     Feedback[]
  creator       User           @relation(fields: [createdBy], references: [id])

  @@index([collegeId])
  @@index([category])
  @@index([scope])
  @@index([createdBy])
}

model Registration {
  id        String             @id @default(uuid())
  eventId   String
  userId    String
  status    RegistrationStatus @default(pending)
  timestamp DateTime           @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Feedback {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  rating    Int
  comments  String?
  timestamp DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model AdminLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
